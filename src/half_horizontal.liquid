<div class="layout layout--row layout--top">
  <!-- Monitors Grid -->
  <div
    class="columns"
    data-overflow="true"
    data-overflow-max-cols="{% if total_monitors < 10 %}1{% else %}3{% endif %}"
    data-overflow-max-cols-lg="{% if total_monitors < 10 %}2{% else %}3{% endif %}"
    data-overflow-max-cols-portrait="{% if total_monitors < 10 %}1{% else %}2{% endif %}"
    data-overflow-max-cols-lg-portrait="{% if total_monitors < 10 %}1{% else %}2{% endif %}"
    data-overflow-counter="true"
  >
    <div class="column">
      {%- for monitor in sorted_monitors -%}
        {% render 'monitor' monitor: monitor %}
      {%- endfor -%}
    </div>
  </div>
</div>

{% if monitors.size <= 15 %}
<div class="title_bar">
  <img class="image image-stroke image-stroke--small" src="https://avatars.githubusercontent.com/u/4648252?s=200&v=4" width="28" height="28" />
  <span class="title">{{ up_monitors }} up, {{ down_monitors }} down, {{ paused_monitors }} paused</span>
  <span class="instance">{{ trmnl.plugin_settings.instance_name | default: 'My Sites' }}</span>
</div>
{% endif %}
